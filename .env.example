# Copy this file to .env and add your actual API keys
# NEVER commit the .env file to version control

# Required: Groq API key (free at console.groq.com)
GROQ_API_KEY=your_groq_api_key_here

# Optional: Tavily web search API key
# Get a free key at https://app.tavily.com (1,000 searches/month free)
TAVILY_API_KEY=your_tavily_key_here

# Optional: model override (default: llama-3.3-70b-versatile)
# Other free Groq models: llama-3.1-8b-instant, mixtral-8x7b-32768
MODEL_NAME=llama-3.3-70b-versatile

# Optional: other settings
LOG_LEVEL=INFO
LOG_FILE=pipeline.log
MAX_TOKENS=1024
API_TIMEOUT=60
